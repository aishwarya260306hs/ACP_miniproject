void drawRectangle(int x, int y, int width, int height, char ch)
{
    int i;

    for(i = 0; i < width; i++)
    {
        plot(x, y + i, ch);
        plot(x + height - 1, y + i, ch);
    }

    for(i = 0; i < height; i++)
    {
        plot(x+i,y,ch);
        plot(x+i,y+width-1,ch);
    }
}
void drawLine(int x1, int y1, int x2, int y2, char ch)
{
    int dx = abs(x2 - x1);
    int dy = abs(y2 - y1);

    int sx = (x1 < x2) ? 1 : -1;
    int sy = (y1 < y2) ? 1 : -1;

    int err = dx - dy;

    while(1)
    {
        plot(x1, y1, ch);

        if(x1 == x2 && y1 == y2)
            break;

        int e2 = 2 * err;

        if(e2 > -dy)
        { 
            err -= dy;
            x1 += sx;
        }

        if(e2 < dx)
        {
            err += dx;
            y1 += sy;
        }
    }
}
